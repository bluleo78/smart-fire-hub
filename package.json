{
  "name": "smart-fire-hub",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "mkdir -p logs && lsof -ti:8080,3001,5173 | xargs kill -9 2>/dev/null; turbo run dev 2>&1 | tee logs/dev-server.log",
    "dev:full": "pnpm db:up && mkdir -p logs && lsof -ti:8080,3001,5173 | xargs kill -9 2>/dev/null; turbo run dev 2>&1 | tee logs/dev-server.log",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test:e2e": "pnpm --filter firehub-web test:e2e",
    "test:e2e:ui": "pnpm --filter firehub-web test:e2e:ui",
    "test:e2e:headed": "pnpm --filter firehub-web test:e2e:headed",
    "clean": "turbo run clean",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:logs": "docker compose logs -f db",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.5.0"
  },
  "lint-staged": {
    "apps/firehub-web/{src,e2e}/**/*.{ts,tsx}": [
      "eslint --no-warn-ignored --config apps/firehub-web/eslint.config.js"
    ],
    "apps/firehub-ai-agent/src/**/*.ts": [
      "eslint --no-warn-ignored --config apps/firehub-ai-agent/eslint.config.js"
    ]
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
