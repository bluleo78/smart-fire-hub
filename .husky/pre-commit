# pre-commit 훅 — 가벼운 정합성 검사는 항상, 무거운 회귀(E2E + gradle)는 코드 변경이 있을 때만.
# 비코드(.md / docs / IDE 설정 / 이슈 템플릿 등) 단독 커밋은 ~수 초 안에 통과한다.
# 코드 커밋은 변경 영역을 분석해 도메인 한정 + smoke 또는 전체 풀을 선택 실행한다(#257).
# 풀 회귀 안전망은 .husky/pre-push 가 담당.

npx lint-staged
pnpm typecheck

# 1) 스테이지된 파일 분석
CHANGED=$(git diff --cached --name-only --diff-filter=ACMR)

# 2) 비코드만? → skip
NEEDS_REGRESSION=$(printf '%s\n' "$CHANGED" | grep -vE '^(docs/|.*\.md$|LICENSE.*|\.gitignore$|\.gitattributes$|\.vscode/|\.idea/|\.editorconfig$|\.github/(ISSUE_TEMPLATE|PULL_REQUEST_TEMPLATE))' | grep .)
if [ -z "$NEEDS_REGRESSION" ]; then
  echo "[pre-commit] 비코드 변경만 감지 — E2E + gradle test skip"
  exit 0
fi

# 3) 공유 영역 또는 매핑 외 코드 변경 → 전체 풀
#    - apps/firehub-web/src 하위 중 pages/<domain>/ 가 아닌 경로(components, api, lib, hooks, types, 루트 ts/css)
#    - apps/firehub-web 루트 config / package.json / e2e 자체 변경
WEB_DOMAINS_RE='admin|ai-insights|analytics|data|pipeline|settings'

FORCE_FULL=$(printf '%s\n' "$CHANGED" | grep -E '^apps/firehub-web/(src/(components|api|lib|hooks|types|main\.tsx|App\.tsx|index\.css|router\.tsx|vite-env\.d\.ts|setupTests\.ts)|(vite|playwright|eslint|postcss|tailwind)\.config\.(ts|js|cjs|mjs)|tsconfig.*\.json|package\.json|e2e/|scripts/)' | head -1)

# pages 하위 도메인 디렉토리 변경 식별
WEB_PAGE_CHANGES=$(printf '%s\n' "$CHANGED" | grep -E '^apps/firehub-web/src/pages/' || true)
NON_DOMAIN_PAGE=$(printf '%s\n' "$WEB_PAGE_CHANGES" | grep -vE "^apps/firehub-web/src/pages/($WEB_DOMAINS_RE)/" || true)

if [ -n "$FORCE_FULL" ] || [ -n "$NON_DOMAIN_PAGE" ]; then
  echo "[pre-commit] 공유 영역/매핑 외 변경 감지 — 전체 E2E 실행"
  pnpm test:e2e || exit 1
elif [ -n "$WEB_PAGE_CHANGES" ]; then
  # 4) 도메인 단독 변경 → 도메인 외 smoke + 해당 도메인 전수 (중복 0)
  DOMAINS=$(printf '%s\n' "$WEB_PAGE_CHANGES" | sed -E 's|^apps/firehub-web/src/pages/([^/]+)/.*$|\1|' | sort -u)
  DOMAINS_RE=$(echo $DOMAINS | tr ' ' '|')
  DOMAINS_STR=$(echo $DOMAINS | tr '\n' ' ')
  echo "[pre-commit] 도메인 한정 변경 감지: $DOMAINS_STR— 도메인 외 smoke + 해당 도메인 전수 실행"

  cd apps/firehub-web || exit 1
  # 도메인 spec 인자 + 도메인 외 spec 인자 분리 (중복 회피)
  DOMAIN_SPECS=""
  for d in $DOMAINS; do
    DOMAIN_SPECS="$DOMAIN_SPECS e2e/pages/$d"
  done
  NON_DOMAIN_SPECS=$(find e2e -name "*.spec.ts" | grep -vE "^e2e/pages/($DOMAINS_RE)/" | tr '\n' ' ')

  # 1) 도메인 외 spec 의 smoke 만 (전역 핵심 회귀, 도메인과 중복 없음)
  npx playwright test $NON_DOMAIN_SPECS --grep "@smoke" || exit 1
  # 2) 도메인 전수 (해당 도메인의 모든 test 1회)
  npx playwright test $DOMAIN_SPECS || exit 1
  cd - >/dev/null
else
  # 5) firehub-web 외 변경(api 단독 등) — gradle 단계에서 회귀 검증되므로 E2E skip
  echo "[pre-commit] firehub-web 변경 없음 — E2E skip (gradle 단계에서 회귀 검증)"
fi

# 6) Gradle — 모든 코드 변경 케이스에서 실행. build-cache 로 변경 없으면 즉시 통과.
cd apps/firehub-api && ./gradlew test -x generateJooq --build-cache --configuration-cache
